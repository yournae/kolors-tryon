# Hugging Face API Token(s) — for Photo-to-Video feature
# Generate: https://huggingface.co/settings/tokens → New token
# Scopes needed: Inference API (read)
#
# Single token:
# HF_TOKENS=hf_xxxxxxxxxxxxxxxxxxxxxxxx
#
# Multiple tokens (comma-separated, for rotation):
# HF_TOKENS=hf_token1,hf_token2,hf_token3
HF_TOKENS=hf_xxxxxxxxxxxxxxxxxxxxxxxx
